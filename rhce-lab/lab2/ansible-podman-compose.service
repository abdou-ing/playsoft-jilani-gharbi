[Unit]
Description=Ansible via Podman containers
Requires=network.target
After=network.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/root
ExecStart=/bin/bash /root/common_configured.sh
#ExecStart=/bin/bash -c "/root/common_configured.sh"
#ExecStop=/usr/bin/podman-compose down
User=root
#Group=your-username

[Install]
WantedBy=multi-user.target